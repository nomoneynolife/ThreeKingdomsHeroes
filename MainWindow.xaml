<Window x:Class="ThreeKingdomsHeroes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThreeKingdomsHeroes"
        mc:Ignorable="d"
        Height="458" Width="800"
        Background="Transparent"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#4CAF50" CornerRadius="8" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45a049"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeroItemStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border" Background="White" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="6" Padding="15">
                            <TextBlock Text="{Binding Name}" FontSize="14" Foreground="#333333"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="10" Background="#F5F5F5" BorderThickness="1" BorderBrush="#E0E0E0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 标题区域 -->
            <Border Grid.Row="0" Background="#2196F3" CornerRadius="10 10 0 0" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="梦塔防*封严武将查询工具" FontSize="24" FontWeight="Bold" Foreground="White" Margin="20,10"/>
                    <Button Grid.Column="1" x:Name="btnClose" Content="×" FontSize="24" FontWeight="Bold" Foreground="White" Background="Transparent" BorderThickness="0" Margin="0,10,20,10" Width="30" Height="30" Click="btnClose_Click"/>
                </Grid>
            </Border>
            
            <!-- 主内容区域 -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 分类按钮区域 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
                    <Button x:Name="btnWei" Content="魏" Style="{StaticResource CategoryButtonStyle}" Click="btnWei_Click"/>
                    <Button x:Name="btnShu" Content="蜀" Style="{StaticResource CategoryButtonStyle}" Click="btnShu_Click"/>
                    <Button x:Name="btnWu" Content="吴" Style="{StaticResource CategoryButtonStyle}" Click="btnWu_Click"/>
                    <Button x:Name="btnNeutral" Content="中立" Style="{StaticResource CategoryButtonStyle}" Click="btnNeutral_Click"/>
                </StackPanel>
                
                <!-- 武将显示区域 -->
                <WrapPanel x:Name="wpHeroes" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10"/>
                <TextBlock x:Name="tbNoData" Grid.Row="1" Text="请选择一个分类" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Visibility="Visible"/>
            </Grid>
        </Grid>
    </Border>
</Window>
